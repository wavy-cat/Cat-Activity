{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "renderSettings": {
      "type": "object",
      "properties": {
        "canvasSize": {
          "type": "integer",
          "description": "The size of the canvas for rendering icons"
        },
        "iconSize": {
          "type": "integer",
          "description": "The size of the icon"
        }
      },
      "required": ["canvasSize", "iconSize"]
    },
    "fileIcons": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "oneOf": [
            {
              "type": "string",
              "description": "A simple string value for the icon"
            },
            {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "description": "The title of the icon"
                },
                "altName": {
                  "type": "string",
                  "description": "An alternative name for the icon"
                },
                "fileNames": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "string"
                  },
                  "description": "A list of file names associated with the icon"
                },
                "fileTypes": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "string"
                  },
                  "description": "A list of file types associated with the icon"
                },
                "extensions": {
                  "type": [
                    "array",
                    "null"
                  ],
                  "items": {
                    "type": "string"
                  },
                  "description": "A list of file extensions associated with the icon"
                },
                "enumName": {
                  "type": "string",
                  "description": "The enumeration name for the icon"
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ignoreIcons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "A list of icons to ignore"
    }
  },
  "required": ["renderSettings", "fileIcons", "ignoreIcons"]
}